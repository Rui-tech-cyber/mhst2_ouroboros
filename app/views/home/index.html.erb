<div class="container" style="max-width: 960px; margin: 2rem auto;">
  <h1>MHST2 Ouroboros</h1>
  <p>ここにモンスター一覧と検索UIを入れる。まずは骨組み</p>

  <!-- 検索ボックス -->
  <h1>モンスター一覧</h1>

  <%= form_with url: monsters_path, method: :get, local: true do %>
    <%= text_field_tag :q, params[:q], placeholder: "モンスター名で検索" %>
    <%= submit_tag "検索" %>
  <% end %>

  <!-- 一覧のプレースホルダー -->
  <ul>
    <% @monsters.each do |monster| %>
      <li style="margin: 0.5rem 0;">
        <%= image_tag monster.image_url, size: "50*50" if monster.image_url.present? %>
        <%= link_to monster.name, monster_path(monster) %>
      </li>
    <% end %>
  </ul>
</div>
