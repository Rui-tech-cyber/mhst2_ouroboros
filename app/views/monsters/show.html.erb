<h2><%= @monster.name %></h2>
<%= image_tag @monster.image_url, width: 100 %>

<div data-controller="monster-state"
     data-monster-id="<%= @monster.id %>"
     data-state-url-template="<%= state_monster_path(@monster, state_id: 'STATE_ID') %>">

  <div id="state-buttons">
    <% @states.each do |state| %>
      <button class="state-btn" data-id="<%= state.id %>" data-action="click->monster-state#change">
        <%= state.state_name %>
      </button>
    <% end %>
  </div>

  <div id="state-detail" style="margin-top:20px;">
    <p><strong>状態:</strong> <span id="state-name"><%= @default_state.state_name %></span></p>
    <p><strong>行動回数:</strong> <span id="action-count"><%= @default_state.action_count %></span></p>
    <p><strong>3すくみ傾向:</strong> <span id="element"><%= @default_state.element %></span></p>
    <p><strong>行動パターン:</strong> <span id="action-pattern"><%= @default_state.action_pattern %></span></p>
    <%= image_tag "#{@default_state.element}.png", id: "element-image", width: 80 %>
  </div>
</div>

<hr>
<div>
  <%= link_to "←モンスター一覧に戻る", root_path, class: "btn btn-secondary" %>
</div>
